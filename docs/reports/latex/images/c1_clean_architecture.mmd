graph TD
    classDef presentation fill:#e3f2fd,stroke:#1565c0,stroke-width:2px,color:#0d47a1,font-weight:bold;
    classDef domain fill:#e8f5e9,stroke:#2e7d32,stroke-width:2px,color:#1b5e20,font-weight:bold;
    classDef data fill:#fff3e0,stroke:#ef6c00,stroke-width:2px,color:#e65100,font-weight:bold;
    classDef layer fill:#fafafa,stroke:#9e9e9e,stroke-width:2px,stroke-dasharray: 5 5,font-weight:bold,color:#424242;

    subgraph PresentationLayer [Presentation Layer]
        A[View: Activity / Fragment]:::presentation
        B[ViewModel]:::presentation
    end

    subgraph DomainLayer [Domain Layer]
        C[Repository Interface]:::domain
    end

    subgraph DataLayer [Data Layer]
        D[Repository Implementation]:::data
        E[(Local Data: Room DB)]:::data
        F((Remote Data: Retrofit/Socket)):::data
    end

    A -- Observes LiveData --> B
    A -- User Actions --> B
    B -- Calls --> C
    D -. Implements .-> C
    D -- Reads / Writes --> E
    D -- Fetches --> F

    class PresentationLayer,DomainLayer,DataLayer layer;
