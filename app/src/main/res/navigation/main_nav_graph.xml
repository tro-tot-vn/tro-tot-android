<?xml version="1.0" encoding="utf-8"?>
<navigation xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/main_nav_graph"
    app:startDestination="@id/homeFragment">

    <!-- Bottom Navigation Fragments -->
    
    <fragment
        android:id="@+id/homeFragment"
        android:name="com.trototvn.trototandroid.ui.main.home.HomeFragment"
        android:label="Home">
        <!-- Actions will be added as features are implemented -->
    </fragment>

    <fragment
        android:id="@+id/searchFragment"
        android:name="com.trototvn.trototandroid.ui.main.search.SearchFragment"
        android:label="Search" />

    <fragment
        android:id="@+id/myPostsFragment"
        android:name="com.trototvn.trototandroid.ui.main.myposts.MyPostsFragment"
        android:label="My Posts" />

    <fragment
        android:id="@+id/chatFragment"
        android:name="com.trototvn.trototandroid.ui.main.chat.ChatFragment"
        android:label="Message" />

    <fragment
        android:id="@+id/profileFragment"
        android:name="com.trototvn.trototandroid.ui.main.profile.ProfileFragment"
        android:label="Profile" />

    <fragment
        android:id="@+id/editProfileFragment"
        android:name="com.trototvn.trototandroid.ui.main.profile.EditProfileFragment"
        android:label="Edit Profile" />

    <fragment
        android:id="@+id/viewHistoryFragment"
        android:name="com.trototvn.trototandroid.ui.main.viewhistory.ViewHistoryFragment"
        android:label="View History" />

    <fragment
        android:id="@+id/savedPostsFragment"
        android:name="com.trototvn.trototandroid.ui.main.savedposts.SavedPostsFragment"
        android:label="Saved Posts" />

    <fragment
        android:id="@+id/accountSettingsFragment"
        android:name="com.trototvn.trototandroid.ui.main.accountsettings.AccountSettingsFragment"
        android:label="Account Settings" />

    <fragment
        android:id="@+id/changePasswordFragment"
        android:name="com.trototvn.trototandroid.ui.main.accountsettings.ChangePasswordFragment"
        android:label="Change Password" />

    <fragment
        android:id="@+id/subscriptionsFragment"
        android:name="com.trototvn.trototandroid.ui.main.subscriptions.SubscriptionsFragment"
        android:label="Subscriptions" />

    <!-- Feature Fragments -->

    <fragment
        android:id="@+id/postDetailFragment"
        android:name="com.trototvn.trototandroid.ui.postdetail.PostDetailFragment"
        android:label="Post Detail">
        <argument
            android:name="postId"
            app:argType="integer" />
    </fragment>

</navigation>
