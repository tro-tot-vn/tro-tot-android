    <color name="md_theme_light_primary">#1D9BF0</color>
    <color name="md_theme_light_onPrimary">#FFFFFF</color>
    <color name="md_theme_light_primaryContainer">#E8F5FE</color>
    <color name="md_theme_light_onPrimaryContainer">#1D9BF0</color>
    
    <color name="md_theme_light_secondary">#F7F9F9</color>
    <color name="md_theme_light_onSecondary">#0F1419</color>
    <color name="md_theme_light_secondaryContainer">#EFF3F4</color>
    <color name="md_theme_light_onSecondaryContainer">#0F1419</color>
    
    <color name="md_theme_light_tertiary">#F7F9F9</color>
    <color name="md_theme_light_onTertiary">#0F1419</color>
