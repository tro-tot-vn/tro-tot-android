    <!-- Convenience aliases for commonly used colors -->
    <color name="primary">@color/md_theme_light_primary</color>
    <color name="background">@color/md_theme_light_background</color>
    <color name="surface">@color/md_theme_light_surface</color>
    <color name="text_primary">@color/md_theme_light_onBackground</color>
    <color name="text_secondary">@color/md_theme_light_onSurfaceVariant</color>
    
    <!-- Custom colors / compat aliases -->
    <color name="gray_300">#EFF3F4</color>
    <color name="gray_600">#536471</color>

    <!-- Icon fills: use @color (not ?attr tint) — fixes invisible icons on API 35/36 -->
    <color name="icon_fill">@color/md_theme_light_onSurface</color>
    <color name="icon_fill_muted">@color/md_theme_light_onSurfaceVariant</color>
    <color name="icon_fill_inverse">@color/md_theme_light_surface</color>
    <color name="icon_outline">@color/md_theme_light_outlineVariant</color>
    <color name="icon_error">@color/md_theme_light_error</color>
