<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="8dp"
    android:background="@color/white"
    android:orientation="horizontal"
    android:padding="12dp">

    <!-- Thumbnail with Info -->
    <LinearLayout
        android:layout_width="100dp"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <ImageView
            android:id="@+id/ivThumbnail"
            android:layout_width="100dp"
            android:layout_height="100dp"
            android:contentDescription="Post thumbnail"
            android:scaleType="centerCrop"
            android:src="@drawable/ic_default_avatar" />

        <!-- Bottom Info: Last Update + Image Count -->
        <LinearLayout
            android:id="@+id/layoutBottomInfo"
            android:layout_width="100dp"
            android:layout_height="wrap_content"
            android:background="#1a000000"
            android:gravity="center"
            android:orientation="horizontal"
            android:paddingHorizontal="4dp"
            android:paddingVertical="2dp"
            android:visibility="gone">

            <TextView
                android:id="@+id/tvLastUpdate"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="2p trước"
                android:textColor="@color/white"
                android:textSize="10sp"
                android:visibility="gone" />

            <ImageView
                android:layout_width="12dp"
                android:layout_height="12dp"
                android:layout_marginStart="4dp"
                android:contentDescription="Image count icon"
                android:scaleType="centerInside"
                android:src="@drawable/ic_camera"
                app:tint="@color/white" />

            <TextView
                android:id="@+id/tvImageCount"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="2dp"
                android:text="5"
                android:textColor="@color/white"
                android:textSize="10sp" />
        </LinearLayout>
    </LinearLayout>

    <!-- Content Section -->
    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical"
        android:paddingStart="12dp"
        android:paddingEnd="12dp">

        <!-- Title -->
        <TextView
            android:id="@+id/tvTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:ellipsize="end"
            android:maxLines="2"
            android:text="Phòng trọ cao cấp"
            android:textColor="@color/black"
            android:textSize="14sp"
            android:textStyle="bold" />

        <!-- Price and Area -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/tvPrice"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="5.0M/tháng"
                android:textColor="#FF6B35"
                android:textSize="12sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvArea"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="25m²"
                android:textColor="#666"
                android:textSize="12sp" />
        </LinearLayout>

        <!-- Location (moved up) -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <ImageView
                android:id="@+id/ivLocationIcon"
                android:layout_width="16dp"
                android:layout_height="16dp"
                android:contentDescription="Location icon"
                android:src="@drawable/ic_land_layer_location"
                app:tint="#999" />

            <TextView
                android:id="@+id/tvLocation"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:paddingStart="4dp"
                android:paddingEnd="4dp"
                android:text="TP. Hồ Chí Minh"
                android:textColor="#666"
                android:textSize="12sp" />
        </LinearLayout>

        <!-- Poster Info (moved down) -->
        <LinearLayout
            android:id="@+id/layoutPoster"
            android:layout_width="match_parent"
            android:layout_height="24dp"
            android:layout_marginTop="4dp"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:visibility="gone">

            <ImageView
                android:id="@+id/ivPosterAvatar"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:contentDescription="Poster avatar"
                android:layout_marginStart="-2dp"
                android:scaleType="centerInside"
                android:src="@drawable/ic_default_avatar" />

            <TextView
                android:id="@+id/tvPosterName"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:gravity="center_vertical"
                android:paddingStart="6dp"
                android:paddingEnd="6dp"
                android:text="Nguyễn Văn A"
                android:textColor="#333"
                android:textSize="12sp" />
        </LinearLayout>
    </LinearLayout>

    <!-- Save Button -->
    <ImageButton
        android:id="@+id/btnSave"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:layout_gravity="center"
        android:background="?attr/selectableItemBackground"
        android:contentDescription="Save post"
        android:scaleType="centerInside"
        android:src="@drawable/ic_bookmark"
        android:visibility="gone"
        app:tint="#FF6B35" />

</LinearLayout>



