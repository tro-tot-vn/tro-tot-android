<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fitsSystemWindows="true"
    android:background="?android:attr/colorBackground"
    android:orientation="vertical">

    <!-- Minimalist Premium Toolbar Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingHorizontal="16dp">

        <androidx.appcompat.widget.AppCompatImageView
            android:id="@+id/ivBack"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:background="?android:attr/selectableItemBackgroundBorderless"
            android:clickable="true"
            android:contentDescription="Quay lại"
            android:focusable="true"
            android:padding="8dp"
            android:src="@drawable/arrow_small_left"
            app:tint="?attr/colorOnSurface" />

        <TextView
            android:id="@+id/tvHeaderTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="24dp"
            android:text="Đăng tin mới"
            android:textColor="?attr/colorOnSurface"
            android:textSize="18sp"
            android:textStyle="bold" />
    </LinearLayout>

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="?attr/colorOutline" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- Section 1: Media Files Upload & Management -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="HÌNH ẢNH &amp; VIDEO TRỌ"
                android:textColor="?attr/colorOnSurface"
                android:textSize="12sp"
                android:textStyle="bold"
                android:letterSpacing="0.08"
                android:layout_marginBottom="8dp" />

            <!-- Dashed Style Selector Cards Row -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="16dp">

                <!-- Upload Images Card -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/btnUploadImagesCard"
                    android:layout_width="0dp"
                    android:layout_height="100dp"
                    android:layout_weight="1"
                    android:layout_marginEnd="8dp"
                    app:cardCornerRadius="8dp"
                    app:cardElevation="0dp"
                    app:strokeColor="?attr/colorOutline"
                    app:strokeWidth="1dp"
                    android:clickable="true"
                    android:focusable="true">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:padding="8dp">

                        <ImageView
                            android:layout_width="32dp"
                            android:layout_height="32dp"
                            android:src="@drawable/ic_camera"
                            />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Tải ảnh lên"
                            android:textSize="12sp"
                            android:textStyle="bold"
                            android:textColor="?attr/colorOnSurface"
                            android:layout_marginTop="4dp" />

                        <TextView
                            android:id="@+id/tvImagesCardCount"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="ĐĂNG TỐI ĐA 12 HÌNH"
                            android:textSize="9sp"
                            android:textColor="?attr/colorOnSurfaceVariant" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- Upload Video Card -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/btnUploadVideoCard"
                    android:layout_width="0dp"
                    android:layout_height="100dp"
                    android:layout_weight="1"
                    android:layout_marginStart="8dp"
                    app:cardCornerRadius="8dp"
                    app:cardElevation="0dp"
                    app:strokeColor="?attr/colorOutline"
                    app:strokeWidth="1dp"
                    android:clickable="true"
                    android:focusable="true">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:padding="8dp">

                        <ImageView
                            android:layout_width="32dp"
                            android:layout_height="32dp"
                            android:src="@drawable/ic_video"
                            />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Tải video lên"
                            android:textSize="12sp"
                            android:textStyle="bold"
                            android:textColor="?attr/colorOnSurface"
                            android:layout_marginTop="4dp" />

                        <TextView
                            android:id="@+id/tvVideoCardStatus"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="ĐĂNG TỐI ĐA 01 VIDEO"
                            android:textSize="9sp"
                            android:textColor="?attr/colorOnSurfaceVariant" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>
            </LinearLayout>

            <!-- Section 1A: Newly Selected Images -->
            <LinearLayout
                android:id="@+id/llNewImagesContainer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="gone"
                android:layout_marginBottom="16dp"
                tools:visibility="visible">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Hình ảnh đã chọn"
                    android:textColor="?attr/colorOnSurfaceVariant"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="8dp" />

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/rvNewImages"
                    android:layout_width="match_parent"
                    android:layout_height="90dp"
                    android:orientation="horizontal"
                    tools:listitem="@layout/item_selected_media" />
            </LinearLayout>

            <!-- Section 1B: Video Preview Card (16:9 Aspect Video Player View) -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/mcvVideoPreviewCard"
                android:layout_width="match_parent"
                android:layout_height="180dp"
                app:cardCornerRadius="8dp"
                app:cardElevation="0dp"
                app:strokeColor="?attr/colorOutline"
                app:strokeWidth="1dp"
                android:visibility="gone"
                android:layout_marginBottom="24dp"
                tools:visibility="visible">

                <FrameLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent">

                    <ImageView
                        android:id="@+id/ivVideoThumbnail"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:background="#1A1A1A"
                        android:scaleType="centerCrop"
                        android:contentDescription="Video Thumbnail" />

                    <!-- Play circle button overlay -->
                    <ImageView
                        android:id="@+id/ivPlayVideoBtn"
                        android:layout_width="48dp"
                        android:layout_height="48dp"
                        android:layout_gravity="center"
                        android:src="@drawable/ic_play_circle"
                        android:background="?android:attr/selectableItemBackgroundBorderless"
                        android:clickable="true"
                        android:focusable="true" />

                    <!-- Bottom label -->
                    <TextView
                        android:id="@+id/tvVideoNameLabel"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="bottom|start"
                        android:layout_margin="12dp"
                        android:text="Video đính kèm"
                        android:textColor="#FFFFFF"
                        android:textSize="11sp"
                        android:textStyle="bold"
                        android:background="#99000000"
                        android:paddingHorizontal="8dp"
                        android:paddingVertical="4dp" />

                    <!-- Delete button in top-right corner -->
                    <FrameLayout
                        android:id="@+id/btnRemoveVideoCard"
                        android:layout_width="28dp"
                        android:layout_height="28dp"
                        android:layout_gravity="top|end"
                        android:layout_margin="8dp"
                        android:background="#B3000000"
                        android:clickable="true"
                        android:focusable="true">

                        <ImageView
                            android:layout_width="14dp"
                            android:layout_height="14dp"
                            android:layout_gravity="center"
                            android:src="@drawable/icons8_close"
                            app:tint="#FFFFFF" />
                    </FrameLayout>
                </FrameLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Section 2: Unified Address Card Trigger -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="ĐỊA CHỈ PHÒNG TRỌ"
                android:textColor="?attr/colorOnSurface"
                android:textSize="12sp"
                android:textStyle="bold"
                android:letterSpacing="0.08"
                android:layout_marginBottom="8dp" />

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/mcvAddressPickerCard"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="8dp"
                app:cardElevation="0dp"
                app:strokeColor="?attr/colorOutline"
                app:strokeWidth="1dp"
                android:clickable="true"
                android:focusable="true"
                android:layout_marginBottom="24dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:padding="16dp">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Vị trí nhà trọ *"
                            android:textSize="11sp"
                            android:textColor="?attr/colorOnSurfaceVariant"
                            android:textStyle="bold" />

                        <TextView
                            android:id="@+id/tvFullAddress"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Chưa thiết lập địa chỉ trọ"
                            android:textSize="14sp"
                            android:textColor="?attr/colorOnSurface"
                            android:textStyle="bold"
                            android:layout_marginTop="4dp" />
                    </LinearLayout>

                    <ImageView
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:src="@drawable/arrow_small_left"
                        android:rotation="180"
                        />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Section 3: Room Detailed Properties -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="THÔNG TIN BÀI VIẾT"
                android:textColor="?attr/colorOnSurface"
                android:textSize="12sp"
                android:textStyle="bold"
                android:letterSpacing="0.08"
                android:layout_marginBottom="8dp" />

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="8dp"
                app:cardElevation="0dp"
                app:strokeColor="?attr/colorOutline"
                app:strokeWidth="1dp"
                android:layout_marginBottom="24dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <!-- Title input with length constraints -->
                    <com.google.android.material.textfield.TextInputLayout
                        android:id="@+id/tilTitle"
                        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:hint="Tiêu đề bài đăng *"
                        app:boxStrokeColor="?attr/colorOnSurface"
                        app:hintTextColor="?attr/colorOnSurface"
                        app:counterEnabled="true"
                        app:counterMaxLength="70"
                        android:layout_marginBottom="16dp">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/etTitle"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:inputType="text"
                            android:maxLines="1"
                            android:textColor="?attr/colorOnSurface" />
                    </com.google.android.material.textfield.TextInputLayout>

                    <!-- Price & Acreage input row with suffix labels -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginBottom="16dp">

                        <!-- Rent Price -->
                        <com.google.android.material.textfield.TextInputLayout
                            android:id="@+id/tilPrice"
                            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1.2"
                            android:layout_marginEnd="8dp"
                            android:hint="Giá thuê *"
                            app:suffixText="đ/tháng"
                            app:suffixTextColor="?attr/colorOnSurfaceVariant"
                            app:boxStrokeColor="?attr/colorOnSurface"
                            app:hintTextColor="?attr/colorOnSurface">

                            <com.google.android.material.textfield.TextInputEditText
                                android:id="@+id/etPrice"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:inputType="number"
                                android:maxLines="1"
                                android:textColor="?attr/colorOnSurface" />
                        </com.google.android.material.textfield.TextInputLayout>

                        <!-- Room Acreage -->
                        <com.google.android.material.textfield.TextInputLayout
                            android:id="@+id/tilAcreage"
                            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="0.8"
                            android:hint="Diện tích *"
                            app:suffixText="m²"
                            app:suffixTextColor="?attr/colorOnSurfaceVariant"
                            app:boxStrokeColor="?attr/colorOnSurface"
                            app:hintTextColor="?attr/colorOnSurface">

                            <com.google.android.material.textfield.TextInputEditText
                                android:id="@+id/etAcreage"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:inputType="number"
                                android:maxLines="1"
                                android:textColor="?attr/colorOnSurface" />
                        </com.google.android.material.textfield.TextInputLayout>
                    </LinearLayout>

                    <!-- Interior choice segment chips -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Tình trạng nội thất *"
                        android:textSize="11sp"
                        android:textColor="?attr/colorOnSurfaceVariant"
                        android:textStyle="bold"
                        android:layout_marginBottom="6dp" />

                    <com.google.android.material.chip.ChipGroup
                        android:id="@+id/chipGroupInterior"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        app:singleLine="true"
                        app:singleSelection="true"
                        android:layout_marginBottom="16dp">

                        <com.google.android.material.chip.Chip
                            android:id="@+id/chipInteriorFull"
                            style="@style/Widget.Material3.Chip.Filter"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Đầy đủ nội thất"
                            app:chipMinHeight="36dp" />

                        <com.google.android.material.chip.Chip
                            android:id="@+id/chipInteriorNone"
                            style="@style/Widget.Material3.Chip.Filter"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Nhà trống"
                            app:chipMinHeight="36dp" />
                    </com.google.android.material.chip.ChipGroup>

                    <!-- Room Description with length counter limits -->
                    <com.google.android.material.textfield.TextInputLayout
                        android:id="@+id/tilDescription"
                        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:hint="Mô tả chi tiết phòng trọ *"
                        app:boxStrokeColor="?attr/colorOnSurface"
                        app:hintTextColor="?attr/colorOnSurface"
                        app:counterEnabled="true"
                        app:counterMaxLength="999"
                        android:layout_marginBottom="8dp">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/etDescription"
                            android:layout_width="match_parent"
                            android:layout_height="140dp"
                            android:gravity="top"
                            android:inputType="textMultiLine"
                            android:textColor="?attr/colorOnSurface" />
                    </com.google.android.material.textfield.TextInputLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Character / Field error banner -->
            <TextView
                android:id="@+id/tvFormErrorText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="?attr/colorError"
                android:textSize="13sp"
                android:visibility="gone"
                android:layout_marginBottom="16dp"
                tools:text="Vui lòng điền đầy đủ các thông tin bắt buộc."
                tools:visibility="visible" />

            <!-- Solid Orange Submit Action Button -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnSubmitPost"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:text="ĐĂNG TIN NGAY"
                android:textColor="#FFFFFF"
                android:textStyle="bold"
                android:backgroundTint="#FF6D0B"
                app:cornerRadius="4dp"
                app:elevation="0dp"
                android:layout_marginBottom="24dp" />
        </LinearLayout>
    </ScrollView>
</LinearLayout>
