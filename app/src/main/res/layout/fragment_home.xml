<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?android:attr/colorBackground"
    android:orientation="vertical"
    tools:context=".ui.main.home.HomeFragment">

    <!-- X-style top bar: wordmark only -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="@dimen/toolbar_height"
        android:gravity="center_vertical"
        android:paddingHorizontal="@dimen/spacing_lg"
        android:text="@string/app_name"
        android:textAppearance="@style/TextAppearance.App.Title"
        android:textStyle="bold" />

    <View
        android:layout_width="match_parent"
        android:layout_height="@dimen/divider_height"
        android:background="?attr/colorOutline" />

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- Latest posts -->
            <TextView
                style="@style/TextAppearance.App.Title"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingHorizontal="@dimen/spacing_lg"
                android:paddingTop="@dimen/spacing_lg"
                android:paddingBottom="@dimen/spacing_sm"
                android:text="@string/latest_posts" />

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rvLatestPosts"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:nestedScrollingEnabled="false"
                tools:itemCount="4"
                tools:listitem="@layout/item_post_card" />

            <ProgressBar
                android:id="@+id/pbLatestPosts"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:layout_marginVertical="@dimen/spacing_xxl"
                android:visibility="gone"
                tools:visibility="visible" />

            <LinearLayout
                android:id="@+id/layoutLatestError"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginVertical="@dimen/spacing_xxl"
                android:gravity="center"
                android:orientation="vertical"
                android:paddingHorizontal="@dimen/spacing_lg"
                android:visibility="gone"
                tools:visibility="gone">

                <TextView
                    android:id="@+id/tvLatestError"
                    style="@style/TextAppearance.App.Caption"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    tools:text="Không thể tải bài đăng" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnRetryLatest"
                    style="@style/Widget.App.Button.Text"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/spacing_sm"
                    android:text="@string/retry" />
            </LinearLayout>

            <!-- Recommendations -->
            <LinearLayout
                android:id="@+id/layoutRecommendations"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="gone"
                tools:visibility="visible">

                <View
                    android:layout_width="match_parent"
                    android:layout_height="@dimen/divider_height"
                    android:layout_marginTop="@dimen/spacing_sm"
                    android:background="?attr/colorOutline" />

                <TextView
                    style="@style/TextAppearance.App.Title"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:paddingHorizontal="@dimen/spacing_lg"
                    android:paddingTop="@dimen/spacing_lg"
                    android:paddingBottom="@dimen/spacing_sm"
                    android:text="@string/recommendations_for_you" />

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/rvRecommendations"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:nestedScrollingEnabled="false"
                    tools:itemCount="4"
                    tools:listitem="@layout/item_post_card" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnLoadMore"
                    style="@style/Widget.App.Button.Secondary"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:layout_marginTop="@dimen/spacing_lg"
                    android:layout_marginBottom="@dimen/spacing_lg"
                    android:text="@string/load_more"
                    android:visibility="gone"
                    tools:visibility="visible" />

                <ProgressBar
                    android:id="@+id/pbRecommendations"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:layout_marginVertical="@dimen/spacing_lg"
                    android:visibility="gone" />
            </LinearLayout>

            <View
                android:layout_width="match_parent"
                android:layout_height="@dimen/spacing_lg" />
        </LinearLayout>
    </androidx.core.widget.NestedScrollView>
</LinearLayout>
