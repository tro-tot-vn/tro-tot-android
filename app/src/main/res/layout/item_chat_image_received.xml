<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:paddingVertical="@dimen/spacing_tiny">

    <com.google.android.material.imageview.ShapeableImageView
        android:id="@+id/ivAvatar"
        android:layout_width="32dp"
        android:layout_height="32dp"
        android:layout_marginStart="@dimen/spacing_small"
        android:scaleType="centerCrop"
        app:layout_constraintBottom_toBottomOf="@id/ivContent"
        app:layout_constraintStart_toStartOf="parent"
        app:shapeAppearanceOverlay="@style/ShapeAppearance.App.Circle"
        tools:src="@tools:sample/avatars" />

    <com.google.android.material.imageview.ShapeableImageView
        android:id="@+id/ivContent"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="@dimen/spacing_small"
        android:layout_marginEnd="64dp"
        android:adjustViewBounds="true"
        android:maxWidth="240dp"
        android:maxHeight="320dp"
        android:minWidth="120dp"
        android:minHeight="120dp"
        android:scaleType="centerCrop"
        app:layout_constrainedWidth="true"
        app:layout_constraintStart_toEndOf="@id/ivAvatar"
        app:layout_constraintTop_toTopOf="parent"
        app:shapeAppearanceOverlay="@style/ShapeAppearance.App.ChatBubble.Received"
        tools:srcCompat="@tools:sample/backgrounds/scenic" />

    <com.google.android.material.textview.MaterialTextView
        android:id="@+id/tvTime"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="@dimen/spacing_small"
        android:layout_marginTop="2dp"
        android:textAppearance="@style/TextAppearance.App.Caption"
        android:textSize="11sp"
        app:layout_constraintStart_toStartOf="@id/ivContent"
        app:layout_constraintTop_toBottomOf="@id/ivContent"
        tools:text="15:32" />

</androidx.constraintlayout.widget.ConstraintLayout>
